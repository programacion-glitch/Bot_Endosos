# ─── IMAP (lectura de correos) ───────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=bot@h2oins.com
IMAP_PASSWORD=your_password_here
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=30000

# ─── SMTP (envío de correos) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bot@h2oins.com
SMTP_PASSWORD=your_password_here
SMTP_FROM="H2O Bot <bot@h2oins.com>"

# ─── NowCerts ─────────────────────────────────────────────────────────────────
NOWCERTS_URL=https://www8.nowcerts.com/
NOWCERTS_USER=your_user@h2oins.com
NOWCERTS_PASSWORD=your_password_here

# ─── Revisión interna ─────────────────────────────────────────────────────────
REVIEW_EMAIL=review@h2oins.com

# ─── Archivos ─────────────────────────────────────────────────────────────────
AGENTS_EXCEL_PATH=./data/agents.xlsx
DOWNLOADS_PATH=./downloads

# ─── Playwright ───────────────────────────────────────────────────────────────
HEADLESS=false
BROWSER_SLOW_MO=100

# ─── Reintentos ───────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_MS=5000
